#!/usr/bin/env bash
# orvex.sh/install/bmad — install orvex BMAD modules.
#
#   curl -fsSL orvex.sh/install/bmad | bash
#
# Forces only the orvex modules; bmm is a required dependency; everything
# else (IDE/tools, per-module config) is interactive.
#
# Env overrides:
#   ORVEX_BMAD_REPO            git URL (default: git@github.com:orvexai/bmad-modules)
#   ORVEX_BMAD_DIR             target dir (default: current working dir)
#   ORVEX_BMAD_MODULES         extra official modules beyond bmm (comma-separated, e.g. "tea,gds")
#   ORVEX_BMAD_EXTRA_SOURCES   extra --custom-source URLs (comma-separated, layered onto orvex)
#
# Examples:
#   ORVEX_BMAD_MODULES=tea curl -fsSL orvex.sh/install/bmad | bash       # + Test Architecture
#   ORVEX_BMAD_EXTRA_SOURCES=https://github.com/some/repo \
#     curl -fsSL orvex.sh/install/bmad | bash                            # + another module repo

set -euo pipefail

# ── Self-bootstrap for interactive prompts under curl|bash ───────────────────
# Bash reads the script from stdin lazily under curl|bash; redirecting stdin
# mid-script would hang. Re-download to a temp file + re-exec with /dev/tty.
if [ ! -t 0 ] && [ -e /dev/tty ] && (exec </dev/tty) 2>/dev/null; then
  command -v curl >/dev/null 2>&1 || { echo "ERROR: curl required to self-bootstrap" >&2; exit 1; }
  _SCRIPT_URL="${ORVEX_BMAD_SCRIPT_URL:-https://orvex.sh/install/bmad}"
  _SCRIPT_TMP="$(mktemp -t orvex-bmad.XXXXXX 2>/dev/null || mktemp)"
  trap 'rm -f "$_SCRIPT_TMP"' EXIT
  curl -fsSL "$_SCRIPT_URL" -o "$_SCRIPT_TMP" || { echo "ERROR: download failed: $_SCRIPT_URL" >&2; exit 1; }
  exec bash "$_SCRIPT_TMP" "$@" </dev/tty
fi

REPO="${ORVEX_BMAD_REPO:-git@github.com:orvexai/bmad-modules}"
TARGET_DIR="${ORVEX_BMAD_DIR:-$(pwd)}"
# Pin, don't float to @latest: an unpinned `npx bmad-method` jumping several
# minors on an existing install (e.g. 6.8.0 -> 6.10.0) has been observed to
# choke reading the old manifest ("Cannot read properties of null (reading
# 'modules')") and reset it to a bare `core`-only stub, discarding module
# history for an install/update that otherwise completed fine on disk.
BMAD_METHOD_VERSION="${ORVEX_BMAD_METHOD_VERSION:-6.10.0}"

# Layer additional --custom-source URLs onto the orvex repo.
EXTRA_SOURCES="${ORVEX_BMAD_EXTRA_SOURCES:-}"
SOURCES="$REPO${EXTRA_SOURCES:+,$EXTRA_SOURCES}"

# ── Colors ───────────────────────────────────────────────────────────────────
if [ -t 1 ] && command -v tput >/dev/null 2>&1 && [ "$(tput colors 2>/dev/null || echo 0)" -ge 8 ]; then
  G="$(tput setaf 2)"; D="$(tput dim)"; B="$(tput bold)"; R="$(tput sgr0)"
else
  G=""; D=""; B=""; R=""
fi
fail() { printf "ERROR: %s\n" "$*" >&2; exit 1; }

# ── Pre-flight (silent on success) ───────────────────────────────────────────
command -v node >/dev/null 2>&1 || fail "node not found — install Node.js v20.12+ from https://nodejs.org"
NODE_VER="$(node --version | sed 's/^v//')"
NM="$(printf '%s' "$NODE_VER" | cut -d. -f1)"
NN="$(printf '%s' "$NODE_VER" | cut -d. -f2)"
{ [ "$NM" -lt 20 ] || { [ "$NM" -eq 20 ] && [ "$NN" -lt 12 ]; }; } && fail "node v$NODE_VER too old (need v20.12+)"
command -v npx >/dev/null 2>&1 || fail "npx not found"
command -v git >/dev/null 2>&1 || fail "git not found"
[ -d "$TARGET_DIR" ] || fail "target dir not found: $TARGET_DIR"
cd "$TARGET_DIR"

printf "\n${B}orvex bmad installer${R}  ${D}→ %s${R}\n" "$(pwd)"

# ── Module selector ──────────────────────────────────────────────────────────
# Always installed (non-toggleable): bmm (required by orvex), bmad-linear, bmad-docmost.
# Set ORVEX_BMAD_MODULES env var to skip the prompt (CI / scripted installs).
# Registry mirrored from https://github.com/bmad-code-org/BMAD-METHOD/blob/main/bmad-modules.yaml
if [ -n "${ORVEX_BMAD_MODULES:-}" ]; then
  EXTRA_MODULES="$ORVEX_BMAD_MODULES"
else
  printf "\n  ${D}always installed:${R} ${B}bmm${R} ${D}(required)${R}, ${B}bmad-linear${R}, ${B}bmad-docmost${R} ${D}(orvex)${R}\n"
  printf "\n  ${B}Optional official BMAD modules:${R}\n"
  printf "    ${B}tea${R}        BMad Test Architect — quality strategy + release gates\n"
  printf "    ${B}bmb${R}        BMad Builder — author agents, workflows, modules\n"
  printf "    ${B}cis${R}        Creative Intelligence Suite — brainstorming, design thinking\n"
  printf "    ${B}gds${R}        Game Dev Studio — Unity, Unreal, Godot, Phaser\n"
  printf "    ${B}wds${R}        Whiteport Design Studio — UX-first planning\n"
  printf "\n  ${B}Codes to add${R} ${D}(comma-separated, blank for none):${R} "
  read -r EXTRA_MODULES
fi

# Build the final --modules list. bmm always first. Strip whitespace + every bmm token.
_FILTERED=""
_OLD_IFS="$IFS"; IFS=,
for tok in $(printf '%s' "${EXTRA_MODULES:-}" | tr -d ' '); do
  [ -z "$tok" ] || [ "$tok" = "bmm" ] && continue
  _FILTERED="${_FILTERED:+$_FILTERED,}$tok"
done
IFS="$_OLD_IFS"
MODULES="bmm${_FILTERED:+,$_FILTERED}"
printf "  ${D}installing:${R} ${B}%s${R} ${D}+ orvex modules from %s${R}\n" "$MODULES" "$REPO"
echo

# ── Manifest safety net ───────────────────────────────────────────────────────
# On an existing install, back up the manifest so a botched update (see the
# version-pin note above) can be detected and reverted instead of silently
# leaving an installed project's module history erased.
MANIFEST="_bmad/_config/manifest.yaml"
MANIFEST_BAK=""
if [ -f "$MANIFEST" ]; then
  MANIFEST_BAK="$(mktemp -t orvex-bmad-manifest.XXXXXX 2>/dev/null || mktemp)"
  cp "$MANIFEST" "$MANIFEST_BAK"
fi

# ── Install — interactive, only orvex modules + bmm dep are preselected ──────
# Same command for a fresh install and an upgrade of an existing one — the
# installer itself detects an existing manifest and offers Quick Update /
# Modify. Filter known-cosmetic post-install warnings on stderr so they don't
# clutter. (Stdout stays untouched so interactive prompts work cleanly.)
npx --yes "bmad-method@${BMAD_METHOD_VERSION}" install \
  --directory . \
  --modules "$MODULES" \
  --custom-source "$SOURCES" \
  2> >(grep -vE '^\[warn\] (collectAgentsFromModuleYaml|writeCentralConfig).*module\.yaml.*(lnr|doc)|lnr/module-help\.csv header does not match' >&2)

# If a prior manifest existed, make sure the installer didn't collapse it back
# down to a bare `core`-only stub (the failure mode this pin works around).
if [ -n "$MANIFEST_BAK" ]; then
  PREV_MODULE_COUNT="$(grep -c '^  - name:' "$MANIFEST_BAK" || true)"
  NEW_MODULE_COUNT="$(grep -c '^  - name:' "$MANIFEST" 2>/dev/null || true)"
  if [ "${NEW_MODULE_COUNT:-0}" -lt "${PREV_MODULE_COUNT:-0}" ]; then
    cp "$MANIFEST_BAK" "$MANIFEST"
    rm -f "$MANIFEST_BAK"
    fail "installer reset $MANIFEST from $PREV_MODULE_COUNT module(s) to $NEW_MODULE_COUNT — restored the prior manifest and aborted.
       This usually means bmad-method@${BMAD_METHOD_VERSION} couldn't read the existing manifest.
       Check what changed in the manifest schema between your installed version and ${BMAD_METHOD_VERSION}, or re-run with ORVEX_BMAD_METHOD_VERSION pinned to your currently-installed bmad-method version."
  fi
  rm -f "$MANIFEST_BAK"
fi

# ── Ensure orvex module content is fresh ─────────────────────────────────────
# On an existing install, bmad-method's "Quick Update" path can decide there is
# "no source available" for custom modules and SKIP lnr/doc entirely — even
# though --custom-source was passed — leaving _bmad/lnr/ and _bmad/doc/
# (bin/, data/, overrides/, skills/, commands/) pinned to whatever an earlier
# install copied. That silently starves apply-patch.sh of new patch content
# — the engine's floor-match falls back to the nearest older validated
# <MAJOR.MINOR>/ patch set automatically on a bmm bump, but only if bin/patches/
# itself was ever pulled down in the first place. Work around it: shallow
# clone the source repo and mirror bin/, data/, and overrides/ straight into
# _bmad/<code>/ for each orvex module (idempotent — only changed files are
# rewritten), PLUS skills/ and commands/ into their Claude-side install paths
# (bmad-method installs a custom module's data/ dir but not its bin/, and does
# not re-scan skills/commands/ for entries added without a version bump).
# Must run BEFORE apply-patch.sh, which depends on a fresh bin/patches/.
# Skill/command names and module dirs are disjoint across orvex modules — safe
# to refresh. Best-effort: a clone failure leaves whatever bmad-method installed.
declare -A _MOD_CODE=( [bmad-linear]=lnr [bmad-docmost]=doc )
_SK_SRC="$(mktemp -d 2>/dev/null)"
if [ -n "$_SK_SRC" ] && git clone --depth 1 "$REPO" "$_SK_SRC" >/dev/null 2>&1; then
  _MOD_N=0
  for _mod in bmad-docmost bmad-linear; do
    _code="${_MOD_CODE[$_mod]}"
    for _sub in bin data overrides; do
      [ -d "$_SK_SRC/$_mod/$_sub" ] || continue
      mkdir -p "_bmad/$_code/$_sub"
      while IFS= read -r -d '' _f; do
        _rel="${_f#"$_SK_SRC/$_mod/$_sub/"}"
        _dest="_bmad/$_code/$_sub/$_rel"
        mkdir -p "$(dirname "$_dest")"
        if ! cmp -s "$_f" "$_dest" 2>/dev/null; then
          cp -f "$_f" "$_dest" && _MOD_N=$((_MOD_N + 1))
        fi
      done < <(find "$_SK_SRC/$_mod/$_sub" -type f -print0)
    done
  done
  [ "$_MOD_N" -gt 0 ] && printf "  ${D}synced %s module file(s) → _bmad/{lnr,doc}/{bin,data,overrides}/${R}\n" "$_MOD_N"

  _SK_N=0
  for _mod in bmad-docmost bmad-linear; do
    [ -d "$_SK_SRC/$_mod/skills" ] || continue
    for _sk in "$_SK_SRC/$_mod/skills"/*/; do
      [ -f "${_sk}SKILL.md" ] || continue
      _n="$(basename "$_sk")"
      mkdir -p ".claude/skills/$_n"
      if ! cmp -s "${_sk}SKILL.md" ".claude/skills/$_n/SKILL.md" 2>/dev/null; then
        cp -f "${_sk}SKILL.md" ".claude/skills/$_n/SKILL.md" && _SK_N=$((_SK_N + 1))
      fi
    done
  done
  [ "$_SK_N" -gt 0 ] && printf "  ${D}synced %s module skill(s) → .claude/skills/${R}\n" "$_SK_N"

  # Same story for plugin SLASH COMMANDS: bmad-method installs a custom module's
  # data/overrides but does NOT surface its commands/ as Claude slash commands.
  # Copy each module's commands/*.md → .claude/commands/ idempotently so the
  # /doc-* commands work on this (BMAD-module) install path, not just on /plugin
  # install. Command filenames are disjoint across orvex modules.
  _CMD_N=0
  for _mod in bmad-docmost bmad-linear; do
    [ -d "$_SK_SRC/$_mod/commands" ] || continue
    mkdir -p .claude/commands
    for _cmd in "$_SK_SRC/$_mod/commands"/*.md; do
      [ -f "$_cmd" ] || continue
      _cn="$(basename "$_cmd")"
      if ! cmp -s "$_cmd" ".claude/commands/$_cn" 2>/dev/null; then
        cp -f "$_cmd" ".claude/commands/$_cn" && _CMD_N=$((_CMD_N + 1))
      fi
    done
  done
  [ "$_CMD_N" -gt 0 ] && printf "  ${D}synced %s slash command(s) → .claude/commands/${R}\n" "$_CMD_N"
else
  printf "  ${D}(warn: could not clone %s to refresh module content — using whatever bmad-method installed)${R}\n" "$REPO"
fi
[ -n "$_SK_SRC" ] && rm -rf "$_SK_SRC"

# ── Patch (idempotent — quiet on success) ────────────────────────────────────
if [ -f "_bmad/lnr/bin/apply-patch.sh" ]; then
  printf "\n"
  bash _bmad/lnr/bin/apply-patch.sh
else
  fail "_bmad/lnr/bin/apply-patch.sh not found — install incomplete?"
fi

# ── Overrides (merge-aware) ──────────────────────────────────────────────────
# bmad-create-story.toml is contributed by BOTH lnr and doc → a blanket copy
# would clobber one module's keys (Linear's tracking_system/adapter OR the
# wiki-first facts). The docmost override is purely additive
# ([workflow].persistent_facts), so UNION its items into the already-copied
# file's persistent_facts array instead of overwriting. All other overrides copy
# straight across (they target disjoint skills).
mkdir -p _bmad/custom
for src in _bmad/lnr/overrides/*.toml _bmad/doc/overrides/*.toml; do
  [ -e "$src" ] || continue
  dest="_bmad/custom/$(basename "$src")"
  if [ "$(basename "$src")" = "bmad-create-story.toml" ] && [ -e "$dest" ]; then
    # Strip full-line comments first so an example array inside a header comment
    # can't confuse extraction; capture only the real persistent_facts items.
    add="$(grep -v '^[[:space:]]*#' "$src" \
           | awk '/persistent_facts[[:space:]]*=[[:space:]]*\[/{f=1;next} f&&/^[[:space:]]*\]/{f=0} f')"
    if [ -n "$add" ]; then
      awk -v add="$add" '
        $0 !~ /^[[:space:]]*#/ && /persistent_facts[[:space:]]*=[[:space:]]*\[/ {pf=1}
        pf && /^[[:space:]]*\]/ && !done {print add; done=1; pf=0}
        {print}
      ' "$dest" > "$dest.tmp" && mv "$dest.tmp" "$dest"
    fi
  else
    cp "$src" "$dest"
  fi
done

# ── Docmost bootstrap via docmost-cli ──────────────────────────────────────────
# Resolves docmost_space (slug from space name) + docmost_default_owner_id
# (UUID from authenticated user). Both required at runtime; we fail loud
# rather than write broken placeholders.

printf "\n${B}Configuring Docmost${R}\n"

command -v docmost-cli >/dev/null 2>&1 || fail "docmost-cli CLI not on PATH.
       install: https://github.com/orvexai/docmost-cli
       then:    docmost-cli auth login --instance <docmost_url> --token <api-key>
       then re-run this installer."

command -v jq >/dev/null 2>&1 || fail "jq required to parse docmost-cli JSON output (apt install jq / brew install jq)"

# Auth check
AUTH_JSON="$(docmost-cli auth status --output json 2>/dev/null)" || fail "docmost-cli not authenticated.
       run: docmost-cli auth login --instance <docmost_url> --token <api-key>"
PROFILE="$(printf '%s' "$AUTH_JSON" | jq -r '.profile')"
INSTANCE="$(printf '%s' "$AUTH_JSON" | jq -r '.instance_url')"
printf "  ${D}auth: %s @ %s${R}\n" "$PROFILE" "$INSTANCE"

# Resolve owner UUID
ME_JSON="$(docmost-cli user me --output json 2>/dev/null)" || fail "docmost-cli user me failed — check auth"
OWNER_ID="$(printf '%s' "$ME_JSON" | jq -r '.id')"
OWNER_EMAIL="$(printf '%s' "$ME_JSON" | jq -r '.email')"
[ -n "$OWNER_ID" ] && [ "$OWNER_ID" != "null" ] || fail "could not extract user id from docmost-cli user me"
printf "  ${D}owner: %s${R} ${B}%s${R}\n" "$OWNER_EMAIL" "$OWNER_ID"

# Pick space (by number, name, or slug)
SPACES_JSON="$(docmost-cli space list --output json 2>/dev/null)" || fail "docmost-cli space list failed"
SPACE_COUNT="$(printf '%s' "$SPACES_JSON" | jq '.items | length')"
[ "$SPACE_COUNT" -gt 0 ] || fail "no Docmost spaces visible — check your auth profile"

printf "\n  ${B}Pick a space for this project:${R}\n"
printf '%s' "$SPACES_JSON" | jq -r '.items as $arr | range(0; ($arr | length)) | "    \(. + 1). \($arr[.].name)  [\($arr[.].slug)]"'

printf "\n  ${B}Number, name, or slug:${R} "
read -r SPACE_INPUT
[ -n "$SPACE_INPUT" ] || fail "space selection required"

SPACE_SLUG=""
# numeric → index
if [ "$SPACE_INPUT" -eq "$SPACE_INPUT" ] 2>/dev/null; then
  SPACE_SLUG="$(printf '%s' "$SPACES_JSON" | jq -r --argjson i "$((SPACE_INPUT - 1))" '.items[$i].slug // empty')"
fi
# fallback: match by exact name (case-insensitive) or slug
if [ -z "$SPACE_SLUG" ]; then
  SPACE_SLUG="$(printf '%s' "$SPACES_JSON" | jq -r --arg q "$SPACE_INPUT" '
    [.items[] | select(
      .slug == $q
      or .name == $q
      or (.name | ascii_downcase) == ($q | ascii_downcase)
    )] | first.slug // empty
  ')"
fi
[ -n "$SPACE_SLUG" ] && [ "$SPACE_SLUG" != "null" ] || fail "space '$SPACE_INPUT' not found.
       Available: $(printf '%s' "$SPACES_JSON" | jq -r '[.items[].slug] | join(", ")')"
SPACE_NAME="$(printf '%s' "$SPACES_JSON" | jq -r --arg s "$SPACE_SLUG" '[.items[] | select(.slug == $s)] | first.name')"
printf "  ${D}space:${R} ${B}%s${R}  ${D}(%s)${R}\n" "$SPACE_NAME" "$SPACE_SLUG"

# Write team-shared config (committable) — slug only
cat > _bmad/custom/config.toml <<TOML
# Generated by orvex.sh/install/bmad — safe to edit, safe to commit.
# Team-shared per-project orvex BMAD config.

[modules.doc]
docmost_space = "$SPACE_SLUG"
TOML

# Write per-user config (gitignored by BMAD's _bmad/custom/*.user.toml convention)
cat > _bmad/custom/config.user.toml <<TOML
# Generated by orvex.sh/install/bmad — per-user overrides; DO NOT commit.
# Re-run the installer to refresh after re-authenticating docmost-cli.

[modules.doc]
docmost_default_owner_id = "$OWNER_ID"
TOML

# ── Done ─────────────────────────────────────────────────────────────────────
COUNT="$(ls _bmad/custom/*.toml 2>/dev/null | wc -l | tr -d ' ')"
printf "\n${G}✓ orvex BMAD modules installed${R}  ${D}(%s files in _bmad/custom/)${R}\n" "$COUNT"
printf "  ${D}commit:${R}  ${B}git add _bmad/custom && git commit -m 'chore(bmad): orvex modules'${R}\n"
printf "  ${D}upgrade:${R} ${B}_bmad/lnr/bin/apply-patch.sh${R} ${D}after every upstream Quick Update${R}\n\n"
